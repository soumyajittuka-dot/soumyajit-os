# Soumyajit OS Makefile - NET + GFX + KEYBOARD BUILD

CC = gcc
AS = nasm
LD = ld

# 32-bit freestanding flags
CFLAGS = -m32 -std=gnu99 -ffreestanding -O2 -Wall -Wextra -c -fno-stack-protector -nostdinc -I.
ASFLAGS = -f elf32
LDFLAGS = -m elf_i386 -T linker.ld -nostdlib -z noexecstack

# OBJECT FILES GROUPING
BOOT_OBJ = kernel_asm.o

KERNEL_CORE_OBJ = kernel.o gdt.o idt.o mm.o paging.o ports.o string.o timer.o

DRIVER_OBJ = keyboard.o screen.o vga.o pci.o

# NET MODULE
NET_OBJ = e1000.o

# GFX MODULE - future er jonno ready
GFX_OBJ = 

# SCHEDULER + SHELL
SYS_OBJ = scheduler.o command.o

OBJ = $(BOOT_OBJ) $(KERNEL_CORE_OBJ) $(DRIVER_OBJ) $(NET_OBJ) $(GFX_OBJ) $(SYS_OBJ)

all: kernel.bin

# Linker dependency add kora ache
kernel.bin: $(OBJ) linker.ld
	$(LD) $(LDFLAGS) $(OBJ) -o kernel.bin
	@echo "Build complete: kernel.bin size:"
	@ls -lh kernel.bin | awk '{print $$5}'

# Assembly files
%.o: %.asm
	$(AS) $(ASFLAGS) $< -o $@

# C files  
%.o: %.c
	$(CC) $(CFLAGS) $< -o $@

clean:
	rm -rf *.o kernel.bin soumyajit_os.iso iso
	@echo "Cleaned all build files"

iso: kernel.bin
	mkdir -p iso/boot/grub
	cp kernel.bin iso/boot/
	echo 'set timeout=3' > iso/boot/grub/grub.cfg
	echo 'set default=0' >> iso/boot/grub/grub.cfg
	echo 'menuentry "Soumyajit OS [NET+GFX+KB]" { multiboot /boot/kernel.bin; boot; }' >> iso/boot/grub/grub.cfg
	grub-mkrescue -o soumyajit_os.iso iso
	@echo "ISO created: soumyajit_os.iso"

# Debug build - no optimization, with symbols
debug: CFLAGS += -O0 -g
debug: clean kernel.bin

# Run in QEMU with network
run: iso
	qemu-system-i386 -cdrom soumyajit_os.iso -netdev user,id=n1 -device e1000,netdev=n1 -m 128M

.PHONY: all clean iso debug run
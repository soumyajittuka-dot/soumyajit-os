CC = gcc
AS = nasm
LD = ld

CFLAGS = -m32 -std=gnu99 -ffreestanding -O2 -Wall -Wextra -c
ASFLAGS = -f elf32
LDFLAGS = -m elf_i386 -T linker.ld -nostdlib -z noexecstack

OBJ = kernel_asm.o kernel.o command.o gdt.o idt.o e1000.o keyboard.o mm.o paging.o pci.o ports.o scheduler.o screen.o vga.o string.o timer.o

all: kernel.bin

kernel.bin: $(OBJ)
	$(LD) $(LDFLAGS) $(OBJ) -o kernel.bin

kernel_asm.o: kernel.asm
	$(AS) $(ASFLAGS) kernel.asm -o kernel_asm.o

kernel.o: kernel.c
	$(CC) $(CFLAGS) kernel.c -o kernel.o

command.o: command.c
	$(CC) $(CFLAGS) command.c -o command.o

gdt.o: gdt.c
	$(CC) $(CFLAGS) gdt.c -o gdt.o

idt.o: idt.c
	$(CC) $(CFLAGS) idt.c -o idt.o

e1000.o: e1000.c
	$(CC) $(CFLAGS) e1000.c -o e1000.o

keyboard.o: keyboard.c
	$(CC) $(CFLAGS) keyboard.c -o keyboard.o

mm.o: mm.c
	$(CC) $(CFLAGS) mm.c -o mm.o

paging.o: paging.c
	$(CC) $(CFLAGS) paging.c -o paging.o

pci.o: pci.c
	$(CC) $(CFLAGS) pci.c -o pci.o

ports.o: ports.c
	$(CC) $(CFLAGS) ports.c -o ports.o

scheduler.o: scheduler.c
	$(CC) $(CFLAGS) scheduler.c -o scheduler.o

screen.o: screen.c
	$(CC) $(CFLAGS) screen.c -o screen.o

vga.o: vga.c
	$(CC) $(CFLAGS) vga.c -o vga.o

string.o: string.c
	$(CC) $(CFLAGS) string.c -o string.o

timer.o: timer.c
	$(CC) $(CFLAGS) timer.c -o timer.o

clean:
	rm -rf *.o kernel.bin soumyajit_os.iso iso

iso: kernel.bin
	mkdir -p iso/boot/grub
	cp kernel.bin iso/boot/
	echo 'set timeout=0' > iso/boot/grub/grub.cfg
	echo 'set default=0' >> iso/boot/grub/grub.cfg
	echo 'menuentry "Soumyajit OS" { multiboot /boot/kernel.bin; boot; }' >> iso/boot/grub/grub.cfg
	grub-mkrescue -o soumyajit_os.iso iso
